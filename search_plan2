#### [NEW] `embeddingClient.js`
**Location:** `AI_shared_memory/src/embeddingClient.js`

```javascript
/**
 * EmbeddingClient
 * Lightweight replacement for VectorMemoryClassifier.
 * Generates embeddings via backend API, searches locally.
 */

export class EmbeddingClient {
  constructor(apiBaseUrl) {
    this.apiBaseUrl = apiBaseUrl;
    this._cache = new Map(); // Avoid duplicate API calls for same text
  }

  async generateEmbedding(text) {
    const key = text.trim().toLowerCase();
    if (this._cache.has(key)) return this._cache.get(key);

    try {
      const res = await fetch(`${this.apiBaseUrl}/api/embed`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ text })
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const { embedding } = await res.json();

      // LRU-style cache cap at 50 entries
      if (this._cache.size >= 50) {
        this._cache.delete(this._cache.keys().next().value);
      }
      this._cache.set(key, embedding);
      return embedding;
    } catch (e) {
      console.warn('EmbeddingClient: generateEmbedding failed:', e.message);
      return null;
    }
  }

  cosineSimilarity(a, b) {
    if (!a || !b || a.length !== b.length) return 0;
    let dot = 0, normA = 0, normB = 0;
    for (let i = 0; i < a.length; i++) {
      dot += a[i] * b[i];
      normA += a[i] * a[i];
      normB += b[i] * b[i];
    }
    const denom = Math.sqrt(normA) * Math.sqrt(normB);
    return denom === 0 ? 0 : dot / denom;
  }

  /**
   * Semantic search: embed query → cosine for-loop → return top K
   */
  async search(queryText, memories, options = {}) {
    const { topK = 10, threshold = 0.3 } = options;
    if (!queryText || !memories?.length) return [];

    const queryEmbedding = await this.generateEmbedding(queryText);
    if (!queryEmbedding) return []; // Graceful: no crash, no freeze

    return memories
      .filter(m => m.embedding?.length > 0)
      .map(m => ({ memory: m, similarity: this.cosineSimilarity(queryEmbedding, m.embedding) }))
      .filter(r => r.similarity >= threshold)
      .sort((a, b) => b.similarity - a.similarity)
      .slice(0, topK);
  }

  /**
   * Batch-embed memories missing embeddings (for migration of existing data)
   */
  async batchEmbed(memories, progressCallback = null) {
    const results = [];
    let done = 0;
    for (const memory of memories) {
      if (!memory.embedding) {
        const embedding = await this.generateEmbedding(memory.content || memory.text || '');
        if (embedding) memory.embedding = embedding;
      }
      results.push(memory);
      done++;
      if (progressCallback) progressCallback(done, memories.length);
      if (done % 10 === 0) await new Promise(r => setTimeout(r, 0)); // keep UI alive
    }
    return results;
  }
}
```

