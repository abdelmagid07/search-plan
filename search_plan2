#### [NEW] `embed_service.py`
**Location:** `Memory_Box_Website/backend/embed_service.py`

```python
"""
Memory Box Embedding Service
Generates 384-dim vectors using fastembed (all-MiniLM-L6-v2).
Text is processed in RAM only — never logged or stored.
"""

from flask import Blueprint, request, jsonify
import numpy as np
import time

embed_bp = Blueprint('embed', __name__)

# Model loads once at startup and stays in RAM between requests
try:
    from fastembed import TextEmbedding
    _model = TextEmbedding(model_name="sentence-transformers/all-MiniLM-L6-v2")
    print("✅ Embedding model loaded (fastembed / all-MiniLM-L6-v2)")
except Exception as e:
    print(f"⚠️ fastembed failed to load: {e}")
    _model = None


def _generate_embedding(text: str) -> list[float]:
    embeddings = list(_model.embed([text]))
    vector = np.array(embeddings[0], dtype=np.float32)
    norm = np.linalg.norm(vector)
    if norm > 0:
        vector = vector / norm
    return vector.tolist()


@embed_bp.route('/embed', methods=['POST'])
def embed():
    """
    POST /api/embed
    Request:  { "text": "string" }
    Response: { "embedding": [...384 floats], "dimensions": 384, "latency_ms": 45 }
    
    Text is never logged or stored. Processed in RAM, discarded after response.
    """
    start = time.time()
    data = request.get_json()

    if not data or not data.get('text', '').strip():
        return jsonify({"error": "Missing or empty 'text' field"}), 400

    text = data['text']
    if len(text) > 10_000:
        return jsonify({"error": "Text exceeds 10,000 character limit"}), 400

    if _model is None:
        return jsonify({"error": "Embedding model unavailable"}), 503

    try:
        embedding = _generate_embedding(text)
        return jsonify({
            "embedding": embedding,
            "dimensions": len(embedding),
            "latency_ms": round((time.time() - start) * 1000, 2)
        }), 200
    except Exception:
        return jsonify({"error": "Embedding generation failed"}), 500
```

